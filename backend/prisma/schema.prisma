generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  MANAGER
  SALES_USER
  FINANCE_USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ContactStatus {
  LEAD
  CUSTOMER
  ARCHIVED
}

enum DealStage {
  NEW_LEAD
  CONTACTED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum Plan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  industry     String?
  website      String?
  phone        String?
  address      String?
  plan         Plan          @default(FREE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  contacts     Contact[]
  deals        Deal[]
  tasks        Task[]
  invoices     Invoice[]
  emailLogs    EmailLog[]
  activityLogs ActivityLog[]
}

model User {
  id                  String        @id @default(uuid())
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  email               String        @unique
  passwordHash        String
  role                Role          @default(SALES_USER)
  status              UserStatus    @default(ACTIVE)
  resetToken          String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  assignedContacts Contact[] @relation("ContactAssignee")
  assignedDeals    Deal[]    @relation("DealAssignee")
  assignedTasks    Task[]    @relation("TaskAssignee")
  activities       ActivityLog[]

  @@index([organizationId])
  @@index([role])
}

model Contact {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUserId String?
  assignedUser   User?         @relation("ContactAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  firstName      String
  lastName       String?
  companyName    String?
  email          String?
  phone          String?
  address        String?
  source         String?
  status         ContactStatus @default(LEAD)
  tags           String[]      @default([])
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deals          Deal[]
  tasks          Task[]
  invoices       Invoice[]

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@unique([organizationId, email])
}

model Deal {
  id                String       @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedUserId    String?
  assignedUser      User?        @relation("DealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  title             String
  value             Decimal      @default(0) @db.Decimal(12, 2)
  stage             DealStage    @default(NEW_LEAD)
  status            DealStatus   @default(OPEN)
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tasks             Task[]

  @@index([organizationId, stage])
  @@index([assignedUserId, status])
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId         String?
  deal           Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?        @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(PENDING)
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([assignedUserId, status])
  @@index([dueDate])
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  dueDate        DateTime?
  issuedDate     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          InvoiceItem[]

  @@index([organizationId, status])
  @@index([contactId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model EmailLog {
  id             String       @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipientEmail String
  subject        String
  templateName   String?
  status         EmailStatus  @default(PENDING)
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([status])
}

model ActivityLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType     String?
  entityId       String?
  action         String
  description    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([entityType, entityId])
}
